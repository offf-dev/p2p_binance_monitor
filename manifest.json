{
  "manifest_version": 3,
  "name": "Binance Monitoring Extension",
  "version": "1.1",
  "description": "Monitors Binance prices and alerts on target price",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.binance.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "panel.html",
        "sound/beep.mp3",
        "icon48.jpg",
        "icon128.jpg"
      ],
      "matches": ["*://*.binance.com/*"]
    }
  ],
  "icons": {
    "48": "icon48.jpg",
    "128": "icon128.jpg"
  },
  "action": {
    "default_icon": {
      "16": "icon48.jpg",
      "32": "icon48.jpg",
      "48": "icon48.jpg",
      "128": "icon128.jpg"
    }
  },
  "devtools_page": "devtools.html"
}
